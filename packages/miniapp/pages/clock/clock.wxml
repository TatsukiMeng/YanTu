<view class="page">
  <!-- 实时倒计时 -->
  <view class="countdown-card">
    <text class="countdown-label">距考研还有</text>
    <view class="countdown-main">
      <text class="countdown-days">{{daysLeft}}</text>
      <text class="countdown-unit">天</text>
    </view>
    <view class="countdown-tick">
      <text class="tick-num">{{hoursLeft}}</text>
      <text class="tick-colon">:</text>
      <text class="tick-num">{{minutesLeft}}</text>
      <text class="tick-colon">:</text>
      <text class="tick-num">{{secondsLeft}}</text>
    </view>
  </view>

  <!-- 连续打卡 + 本月打卡率 -->
  <view class="streak-row">
    <view class="streak-card streak-left">
      <text class="streak-num">{{streak}}</text>
      <text class="streak-label">连续打卡</text>
    </view>
    <view class="streak-card streak-right">
      <text class="streak-num">{{rate}}%</text>
      <text class="streak-label">本月坚持 ({{monthChecked}}/{{todayDate}})</text>
    </view>
  </view>

  <!-- 本月打卡日历 -->
  <view class="calendar-card">
    <text class="card-title">本月打卡</text>
    <view class="calendar-grid">
      <view class="cal-weekday" wx:for="{{weekDays}}" wx:key="*this">{{item}}</view>
      <view
        wx:for="{{calendar}}"
        wx:key="index"
        class="cal-cell {{item.placeholder ? 'placeholder' : ''}} {{item.checked ? 'checked' : ''}} {{item.isToday ? 'today' : ''}} {{item.isFuture ? 'future' : ''}}"
      >
        <text wx:if="{{!item.placeholder}}">{{item.day}}</text>
      </view>
    </view>
  </view>

  <!-- 名言卡片 -->
  <view class="quote-card">
    <text class="quote-text">"{{quote.text}}"</text>
    <text class="quote-author">—— {{quote.author}}</text>
  </view>

  <!-- 打卡按钮 -->
  <view class="checkin-area">
    <view
      class="checkin-btn {{checkedToday ? 'checked' : ''}}"
      bindtap="onCheckIn"
    >
      <text class="checkin-btn-icon">{{checkedToday ? '✓' : '🔥'}}</text>
      <text class="checkin-btn-text">{{checkedToday ? '今日已打卡' : '能量打卡'}}</text>
    </view>
  </view>
</view>
