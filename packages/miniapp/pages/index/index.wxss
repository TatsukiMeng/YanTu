.page { padding-bottom: 120rpx; }

.tabs {
  white-space: nowrap;
  background: #fff;
  padding: 16rpx 20rpx;
  border-bottom: 1rpx solid #eee;
}

.tab-item {
  display: inline-block;
  padding: 12rpx 32rpx;
  font-size: 28rpx;
  color: #666;
  border-radius: 32rpx;
  margin-right: 16rpx;
}

.tab-item.active {
  background: #0052d9;
  color: #fff;
}

.post-list { padding: 20rpx; }

.loading, .empty {
  text-align: center;
  color: #999;
  padding: 40rpx 0;
  font-size: 26rpx;
}

.fab {
  position: fixed;
  right: 40rpx;
  bottom: 200rpx;
  width: 100rpx;
  height: 100rpx;
  background: #0052d9;
  color: #fff;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 48rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 82, 217, 0.4);
}
