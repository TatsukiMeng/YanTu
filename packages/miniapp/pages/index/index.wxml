<view class="page">
  <scroll-view class="tabs" scroll-x>
    <view
      wx:for="{{tabs}}"
      wx:key="*this"
      class="tab-item {{currentTab === index ? 'active' : ''}}"
      data-index="{{index}}"
      bindtap="onTabChange"
    >{{item}}</view>
  </scroll-view>

  <view class="post-list">
    <post-card
      wx:for="{{posts}}"
      wx:key="id"
      post="{{item}}"
      bind:like="onLike"
    />
    <view class="loading" wx:if="{{loading}}">加载中...</view>
    <view class="empty" wx:if="{{!loading && posts.length === 0}}">暂无帖子</view>
  </view>

  <view class="fab" bindtap="onFabTap">+</view>
</view>
