<view class="page">
  <!-- 用户信息 -->
  <view class="user-card" wx:if="{{userInfo}}">
    <image class="user-avatar" src="{{userInfo.avatar_url}}" mode="aspectFill" />
    <view class="user-info">
      <text class="user-name">{{userInfo.nick_name}}</text>
      <text class="user-level">Lv.{{userInfo.level}}</text>
    </view>
  </view>

  <!-- 数据看板 -->
  <view class="stats-grid">
    <view class="stat-item">
      <text class="stat-num">{{stats.checkInDays}}</text>
      <text class="stat-label">累计打卡</text>
    </view>
    <view class="stat-item">
      <text class="stat-num">{{stats.postCount}}</text>
      <text class="stat-label">我的发布</text>
    </view>
    <view class="stat-item">
      <text class="stat-num">{{stats.commentCount}}</text>
      <text class="stat-label">我的评论</text>
    </view>
    <view class="stat-item">
      <text class="stat-num">{{stats.likeCount}}</text>
      <text class="stat-label">获赞数</text>
    </view>
  </view>

  <!-- 发布历史 -->
  <view class="section">
    <text class="section-title">我的发布</text>
    <post-card wx:for="{{myPosts}}" wx:key="id" post="{{item}}" bind:like="onLike" />
    <view class="empty" wx:if="{{!loading && myPosts.length === 0}}">暂无发布</view>
  </view>
</view>
