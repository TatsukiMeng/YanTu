.page { padding: 20rpx; }

.user-card {
  display: flex; align-items: center;
  background: linear-gradient(135deg, #0052d9, #0073e6);
  border-radius: 16rpx; padding: 32rpx; margin-bottom: 24rpx;
}

.user-avatar { width: 96rpx; height: 96rpx; border-radius: 50%; margin-right: 24rpx; background: #eee; }
.user-info { flex: 1; }
.user-name { font-size: 34rpx; font-weight: 500; color: #fff; display: block; }
.user-level { font-size: 24rpx; color: rgba(255,255,255,0.8); margin-top: 6rpx; display: block; }

.stats-grid {
  display: flex; background: #fff; border-radius: 16rpx;
  padding: 28rpx 0; margin-bottom: 24rpx;
}

.stat-item {
  flex: 1; text-align: center;
  display: flex; flex-direction: column; align-items: center;
}
.stat-num { font-size: 40rpx; font-weight: 700; color: #333; }
.stat-label { font-size: 24rpx; color: #999; margin-top: 8rpx; }

.section { background: #fff; border-radius: 16rpx; padding: 24rpx; }
.section-title { font-size: 30rpx; font-weight: 500; margin-bottom: 16rpx; display: block; }

.post-item {
  padding: 20rpx 0; border-bottom: 1rpx solid #f5f5f5;
}
.post-content { font-size: 28rpx; color: #333; line-height: 1.6; }
.post-meta { display: flex; justify-content: space-between; margin-top: 12rpx; }
.post-category { font-size: 22rpx; color: #0052d9; }
.post-time { font-size: 22rpx; color: #999; }

.empty { text-align: center; color: #999; padding: 40rpx 0; font-size: 26rpx; }
