.page { padding: 20rpx; padding-bottom: 120rpx; }

.detail-card {
  background: #fff; border-radius: 16rpx; padding: 24rpx;
}

.author-row { display: flex; align-items: center; margin-bottom: 20rpx; }
.avatar { width: 72rpx; height: 72rpx; border-radius: 50%; margin-right: 16rpx; background: #eee; }
.author-info { flex: 1; }
.nickname { font-size: 28rpx; font-weight: 500; display: block; }
.time { font-size: 24rpx; color: #999; }
.category-tag { font-size: 22rpx; color: #0052d9; background: rgba(0,82,217,0.08); padding: 4rpx 16rpx; border-radius: 8rpx; }

.content { font-size: 30rpx; line-height: 1.8; color: #333; margin-bottom: 20rpx; }

.images { display: flex; flex-direction: column; gap: 16rpx; margin-bottom: 20rpx; }
.detail-image { width: 100%; border-radius: 8rpx; }

.action-row { display: flex; justify-content: flex-end; padding-top: 16rpx; border-top: 1rpx solid #f0f0f0; }
.like-btn { display: flex; align-items: center; gap: 8rpx; padding: 12rpx 24rpx; font-size: 28rpx; }

.comment-section { margin-top: 24rpx; }
.section-title { font-size: 30rpx; font-weight: 500; margin-bottom: 20rpx; }

.comment-item { display: flex; padding: 20rpx 0; border-bottom: 1rpx solid #f5f5f5; }
.comment-avatar { width: 56rpx; height: 56rpx; border-radius: 50%; margin-right: 16rpx; background: #eee; flex-shrink: 0; }
.comment-body { flex: 1; }
.comment-name { font-size: 26rpx; color: #0052d9; display: block; }
.comment-content { font-size: 28rpx; color: #333; display: block; margin-top: 8rpx; }
.comment-time { font-size: 22rpx; color: #999; display: block; margin-top: 6rpx; }

.empty-comments { text-align: center; color: #999; padding: 40rpx 0; font-size: 26rpx; }

.comment-bar {
  position: fixed; left: 0; right: 0; bottom: 0;
  display: flex; align-items: center; padding: 16rpx 20rpx;
  background: #fff; border-top: 1rpx solid #eee; gap: 16rpx;
}
.comment-input {
  flex: 1; height: 64rpx; background: #f5f5f5; border-radius: 32rpx;
  padding: 0 24rpx; font-size: 28rpx;
}
.send-btn {
  color: #0052d9; font-size: 28rpx; padding: 0 20rpx;
}
