.post-card {
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
}

.post-header {
  display: flex;
  align-items: center;
  margin-bottom: 16rpx;
}

.avatar {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  margin-right: 16rpx;
  background: #eee;
}

.post-meta {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.nickname {
  font-size: 28rpx;
  font-weight: 500;
  color: #333;
}

.time {
  font-size: 24rpx;
  color: #999;
  margin-top: 4rpx;
}

.category-tag {
  font-size: 22rpx;
  color: #0052d9;
  background: rgba(0, 82, 217, 0.08);
  padding: 4rpx 16rpx;
  border-radius: 8rpx;
}

.post-content {
  font-size: 28rpx;
  color: #333;
  line-height: 1.6;
  display: -webkit-box;
  -webkit-line-clamp: 3;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.post-images {
  display: flex;
  gap: 12rpx;
  margin-top: 16rpx;
}

.post-image {
  width: 200rpx;
  height: 200rpx;
  border-radius: 8rpx;
  background: #f0f0f0;
}

.post-footer {
  display: flex;
  justify-content: flex-end;
  margin-top: 16rpx;
}

.like-btn {
  display: flex;
  align-items: center;
  gap: 6rpx;
  padding: 8rpx 16rpx;
}

.like-icon {
  font-size: 32rpx;
}

.like-count {
  font-size: 24rpx;
  color: #666;
}
